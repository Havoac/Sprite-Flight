<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label text="Score : 0" name="ScoreLabel" style="align-items: stretch; justify-content: flex-start; align-self: center; font-size: 30px; -unity-text-outline-color: rgb(255, 255, 255); color: rgb(255, 255, 255); align-content: flex-start; top: 50px; bottom: auto; position: relative; left: auto; border-left-color: rgb(255, 255, 255); border-right-color: rgb(255, 255, 255); border-top-color: rgb(255, 255, 255); border-bottom-color: rgb(255, 255, 255); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; border-top-left-radius: 0; border-top-right-radius: 0; border-bottom-right-radius: 0; border-bottom-left-radius: 0; width: 154px; -unity-text-align: middle-center;"/>
    <ui:Button text="Restart" name="RestartButton" style="position: absolute; top: 50%; align-self: center; font-size: 20px; -unity-text-generator: standard; -unity-font-style: bold;"/>
    <ui:VisualElement name="HighScoreContainer" style="flex-grow: 1; -unity-background-image-tint-color: rgb(242, 147, 0); background-size: 25% 25%; background-color: rgb(178, 118, 25); top: 127px; bottom: auto; flex-direction: column-reverse; width: 285px; height: 41px; aspect-ratio: auto; min-width: auto; min-height: auto; max-height: none; position: absolute; left: auto; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; align-self: center; align-content: center; justify-content: flex-start; align-items: stretch;">
        <ui:Label text="High Score : 0" name="HighScoreLabel" style="position: absolute; top: -6px; font-size: 30px; justify-content: space-between; align-content: flex-end; align-self: center; color: rgb(255, 255, 255); -unity-text-outline-color: rgb(255, 255, 255); -unity-background-image-tint-color: rgb(207, 95, 0); border-left-color: rgb(207, 82, 4); border-right-color: rgb(207, 82, 4); border-top-color: rgb(207, 82, 4); border-bottom-color: rgb(207, 82, 4); left: 14px; height: 43px; right: 17px;"/>
    </ui:VisualElement>
</ui:UXML>
